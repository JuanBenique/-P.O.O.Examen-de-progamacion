<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pe.edu.upeu.controller.LoginController">
    <children>
        <AnchorPane AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Circle fill="#ff331f" layoutX="34.0" layoutY="42.0" radius="20.0" stroke="BLACK" strokeType="INSIDE"/>
                <Circle fill="#d7ff1f" layoutX="83.0" layoutY="42.0" radius="20.0" stroke="BLACK" strokeType="INSIDE"/>
                <Circle fill="#1fff5a" layoutX="132.0" layoutY="42.0" radius="20.0" stroke="BLACK" strokeType="INSIDE"/>
                <Label layoutX="183.0" layoutY="28.0" text="Sistema de Ventas de Polos">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>
            </children>
            <padding>
                <Insets bottom="5.0" right="5.0" top="5.0"/>
            </padding>
        </AnchorPane>

        <!-- Banner de polos sin imagen -->
        <AnchorPane layoutY="72.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Label layoutX="88.0" layoutY="60.0" text="👕 SysVentas Polos" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
            </children>
        </AnchorPane>

        <AnchorPane layoutY="222.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <AnchorPane layoutX="14.0" layoutY="14.0" style="-fx-border-color: #b5abd1; -fx-border-radius: 4;"
                            AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0">
                    <children>
                        <Label layoutX="73.0" layoutY="14.0" text="Usuario"/>
                        <TextField fx:id="txtUsuario" layoutX="135.0" layoutY="10.0"/>
                    </children>
                    <padding>
                        <Insets bottom="5.0" top="5.0"/>
                    </padding>
                </AnchorPane>
                <AnchorPane layoutX="14.0" layoutY="60.0" style="-fx-border-color: #b5abd1; -fx-border-radius: 4;"
                            AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0">
                    <children>
                        <Label layoutX="74.0" layoutY="14.0" text="Clave"/>
                        <PasswordField fx:id="txtClave" layoutX="134.0" layoutY="10.0"/>
                    </children>
                    <padding>
                        <Insets bottom="5.0" top="5.0"/>
                    </padding>
                </AnchorPane>
            </children>
        </AnchorPane>

        <AnchorPane layoutX="14.0" layoutY="328.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <GridPane layoutX="14.0" layoutY="14.0"
                          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="5.0"
                          AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                    </rowConstraints>
                    <children>
                        <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" onAction="#login" text="Ingresar"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white;">
                            <GridPane.margin>
                                <Insets right="5.0"/>
                            </GridPane.margin>
                        </Button>
                        <Button maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false" onAction="#cerrar" text="Cerrar"
                                style="-fx-background-color: #f44336; -fx-text-fill: white;"
                                GridPane.columnIndex="1">
                            <GridPane.margin>
                                <Insets left="5.0"/>
                            </GridPane.margin>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="5.0"/>
                    </padding>
                </GridPane>
            </children>
        </AnchorPane>
    </children>
</AnchorPane>