<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="pe.edu.upeu.controller.EmpleadoController"
            prefHeight="500.0" prefWidth="800.0">

    <children>

        <VBox spacing="10" layoutX="20" layoutY="20">

            <TextField fx:id="txtNombre" promptText="Nombre completo"/>
            <TextField fx:id="txtNumero" promptText="Número de empleado"/>
            <TextField fx:id="txtArea" promptText="Área"/>
            <TextField fx:id="txtCargo" promptText="Cargo"/>
            <DatePicker fx:id="dpFecha"/>

            <HBox spacing="10">
                <Button text="Guardar" onAction="#guardarEmpleado"/>
                <Button text="Editar" onAction="#editarEmpleado"/>
                <Button text="Eliminar" onAction="#eliminarEmpleado"/>
            </HBox>

            <TextField fx:id="txtBuscar" promptText="Buscar por área o cargo"/>

            <HBox spacing="10">
                <Button text="Buscar Área" onAction="#buscarArea"/>
                <Button text="Buscar Cargo" onAction="#buscarCargo"/>
                <Button text="Mostrar Todos" onAction="#mostrarTodos"/>
            </HBox>

        </VBox>

        <TableView fx:id="tabla" layoutX="300" layoutY="20" prefWidth="480" prefHeight="400">
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="100"/>
                <TableColumn fx:id="colNumero" text="Número" prefWidth="80"/>
                <TableColumn fx:id="colArea" text="Área" prefWidth="80"/>
                <TableColumn fx:id="colCargo" text="Cargo" prefWidth="80"/>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
            </columns>
        </TableView>

    </children>

</AnchorPane>